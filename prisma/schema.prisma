generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
}

enum ConsentType {
  DATA_STORAGE
  SBCC_FEEDBACK
  RESEARCH_USE
  EXPERT_REVIEW
  REMINDER_EMAILS
}

model User {
  id             String   @id @default(cuid())
  name           String
  email          String   @unique
  passwordHash   String
  role           UserRole @default(USER)
  emailVerified  DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  lastLoginAt    DateTime?

  accounts       Account[]
  sessions       Session[]
  consents       ConsentRecord[]
  assessments    Assessment[]
  reminders      ReminderPreference?
  notifications  Notification[]
}

model ConsentRecord {
  id          String      @id @default(cuid())
  userId      String
  consentType ConsentType
  granted     Boolean
  textVersion String
  createdAt   DateTime    @default(now())

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, consentType])
}

model Assessment {
  id                   String   @id @default(cuid())
  userId               String
  completedAt          DateTime @default(now())
  referencePeriodStart DateTime
  referencePeriodEnd   DateTime
  overallPli           Float
  overallPli100        Float
  pliBase              Float
  balanceFactor        Float
  profileSpread        Float
  version              String

  user                 User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  responses            AssessmentResponse[]
  domainScores         DomainScore[]
  interventionLogs     InterventionLog[]

  @@index([userId, completedAt])
}

model AssessmentResponse {
  id            String     @id @default(cuid())
  assessmentId  String
  itemId        String
  responseValue Int
  scoredValue   Int

  assessment    Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)

  @@index([assessmentId])
}

model DomainScore {
  id               String     @id @default(cuid())
  assessmentId     String
  ruleId           String
  rawScore         Float
  interactionScore Float
  adjustedScore    Float
  band             String

  assessment       Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)

  @@index([assessmentId, ruleId])
}

model ReminderPreference {
  id                    String   @id @default(cuid())
  userId                String   @unique
  emailRemindersEnabled Boolean  @default(true)
  inAppRemindersEnabled Boolean  @default(true)
  monthlyReminderDay    Int      @default(30)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Notification {
  id         String   @id @default(cuid())
  userId     String
  type       String
  title      String
  message    String
  sentAt     DateTime?
  readAt     DateTime?
  status     String

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, sentAt])
}

model InterventionLog {
  id             String     @id @default(cuid())
  userId         String
  assessmentId   String
  ruleId         String
  interventionId String
  status         String
  startedAt      DateTime?
  completedAt    DateTime?

  assessment     Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)

  @@index([assessmentId, ruleId])
}

model EvidenceEntry {
  id               String   @id @default(cuid())
  domainId         String
  interventionId   String?
  title            String
  summary          String
  sourceType       String
  citationText     String?
  url              String?
  evidenceStrength String?
  createdAt        DateTime @default(now())
}

model ExportLog {
  id           String   @id @default(cuid())
  adminUserId  String
  exportType   String
  filtersJson  String
  createdAt    DateTime @default(now())
}

model Account {
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?

  user               User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([sessionToken])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@id([identifier, token])
}
